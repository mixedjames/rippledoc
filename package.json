{
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.2.1",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.5.0",
    "html-webpack-plugin": "^5.6.6",
    "prettier": "^3.8.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "typedoc": "^0.28.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.18",
    "webpack": "^5.105.0",
    "webpack-cli": "^6.0.1"
  },
  "scripts": {
    "watch:tsc": "tsc -b --watch",
    "test": "vitest",
    "docs": "npm run docs --workspaces --if-present",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "lint": "eslint packages",
    "lint:fix": "eslint packages --fix",
    "build:p4-build-env": "webpack --config apps/p4-build-env/webpack.config.js",
    "watch:p4-build-env": "webpack --config apps/p4-build-env/webpack.config.js --watch",
    "build:editor-build-env": "webpack --config apps/editor-build-env/webpack.config.js",
    "watch:editor-build-env": "webpack --config apps/editor-build-env/webpack.config.js --watch",
    "build:electron-test": "webpack --config apps/electron-test/webpack.main.js && webpack --config apps/electron-test/webpack.renderer.js",
    "start:electron-test": "electron apps/electron-test"
  },
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "dependencies": {
    "dompurify": "^3.3.1",
    "marked": "^17.0.5"
  }
}
