<presentation>

<size w="600" h="800" />

<style>
<![CDATA[

@import url('https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400..800;1,400..800&display=swap');

.rdoc-viewport {
  font-family: 'EB Garamond', serif;
  font-size: 18px;
}

.rdoc-section-background {
  background: white;
}

.rdoc-section-title .rdoc-element.rdoc-element-bigTopImg {
  border: 1px solid black;
}

.rdoc-section-title .rdoc-element.rdoc-element-littleBottomImg {
  border: 1px solid black;
}

.rdoc-section-title .rdoc-element.rdoc-element-title {
  font-size: 40px;
}

.rdoc-section-title .rdoc-element.rdoc-element-subtitle {
}

.rdoc-section-title .rdoc-element.rdoc-element-bottom {
  border-top: 1px solid darkgray;
  text-transform: uppercase;
  font-size: 100%;
  color: darkgray;
}


.rdoc-section-slide3 .rdoc-element-parallaxBg {
  background-image: url("../dist/img/stars.jpg");
  background-size: cover;
  background-position-x: left;
}

]]>
</style>

<section name="title" h="slideHeight">

  <textbox l="20" b="elements.title.top-20" r="basisWidth-20" h="200" name="bigTopImg">
  Some image here
  </textbox>

  <textbox l="20" t="slideHeight/2-height/2" r="basisWidth-20" h="content" name="title">
  An introduction to RippleDoc
  </textbox>

  <textbox l="20" t="elements.title.bottom" r="basisWidth-20" h="content" name="subtitle">
  By James Heggie
  </textbox>

  <textbox l="20" b="sectionBottom" r="basisWidth-120" h="content" name="bottom">
  A whistlestop tour of the presentation library
  </textbox>

  <textbox b="sectionBottom-20" w="90" r="basisWidth-20" h="90" name="littleBottomImg">
  <!-- Some image indicating scrolling down  -->
  </textbox>

</section>

<section name="slide2" h="slideHeight">

  <textbox l="20" t="sectionTop+sectionHeight/2-height/2" r="basisWidth-20" h="content" name="tb0">
  At first it all looks like a pretty standard presentation...

    - Text
    - Images
    - Some colour

  ...but keep scrolling.
  </textbox>

</section>

<section h="slideHeight/2" name="slide3">

  <textbox l="0" t="sectionTop" r="basisWidth" h="sectionHeight" name="parallaxBg">
    <scroll-trigger name="st1" start="sectionTop-slideHeight" end="sectionTop+sectionHeight"/>
    <animation trigger="st1" duration="100" scroll-driven="true">
      <keyFrame position="0" backgroundPositionY="0"/>
      <keyFrame position="100" backgroundPositionY="100"/>
    </animation>
  </textbox>
</section>

<section h="slideHeight" name="slide4">
</section>

</presentation>