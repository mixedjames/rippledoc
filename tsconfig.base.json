{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "composite": true,
    "declaration": true,
    "paths": {
      "@rippledoc/core/*": ["packages/core/src/*"],
      "@rippledoc/expressions": ["packages/expressions"],
      "@rippledoc/sanitizer": ["packages/sanitizer"],
      "@rippledoc/presentation": ["packages/presentation"],
      "@rippledoc/presentationBuilder": ["packages/presentationBuilder"],
      "@rippledoc/htmlPresentation": ["packages/htmlPresentation"],
      "@rippledoc/htmlPresentationView": ["packages/htmlPresentationView"]
    },
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
