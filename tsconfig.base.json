{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "composite": true,
    "declaration": true,
    "paths": {
      "@rippledoc/expressions": ["packages/expressions"],
      "@rippledoc/sanitizer": ["packages/sanitizer"],
      "@rippledoc/markdown": ["packages/markdown"],
      "@rippledoc/presentation2": ["packages/presentation2"]
    },
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
