{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "composite": true,
    "declaration": true,
    "paths": {
      "@rippledoc/sanitizer": ["packages/sanitizer"],
      "@rippledoc/markdown": ["packages/markdown"],
      "@rippledoc/presentation4": ["packages/presentation4"],
      "@rippledoc/presentation4/viewAPI": [
        "packages/presentation4/src/viewAPI"
      ],
      "@rippledoc/view-editor": ["packages/view-editor"],
      "@rippledoc/editor-component": ["packages/editor-component"],
      "@rippledoc/dialogs": ["packages/dialogs"]
    },
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
